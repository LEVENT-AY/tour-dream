rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helper functions ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUserId() {
      return request.auth.uid;
    }

    function isOwner(userId) {
      return isSignedIn() && currentUserId() == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(currentUserId())).data.role;
    }

    function getAgentStatus() {
      return get(/databases/$(database)/documents/users/$(currentUserId())).data.agentStatus;
    }

    function hasRole(role) {
      return isSignedIn() && getUserRole() == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isAgent() {
      return hasRole('agent') || isAdmin();
    }

    function isApprovedAgent() {
      return getAgentStatus() == 'approved' && request.auth != null;
    }

    function isCustomer() {
      return hasRole('customer') || isAgent();
    }

    function isSuspendedOrRejectedAgent() {
      return request.auth != null && (getAgentStatus() == 'suspended' || getAgentStatus() == 'rejected');
    }

    function isSafeUserUpdate() {
      // Customers/agents can update only these safe profile fields; role and uid cannot change
      let allowed = ['displayName', 'email', 'phone', 'photoURL', 'address', 'preferences', 'notifications', 'businessName', 'businessType', 'businessAddress', 'description', 'updatedAt'];
      let incomingKeys = request.resource.data.diff(resource.data).affectedKeys();
      return incomingKeys.hasOnly(allowed)
        && request.resource.data.role == resource.data.role
        && request.resource.data.uid == resource.data.uid;
    }

    function isAdminUserUpdate() {
      // Admins may update status/approval fields but can never change role or uid
      let allowed = ['displayName', 'email', 'phone', 'photoURL', 'address', 'preferences', 'agentStatus', 'approved', 'suspended', 'status', 'approvedAt', 'approvedBy', 'rejectedAt', 'rejectedBy', 'rejectedReason', 'suspendedAt', 'suspendedBy', 'updatedAt'];
      let incomingKeys = request.resource.data.diff(resource.data).affectedKeys();
      return incomingKeys.hasOnly(allowed)
        && request.resource.data.role == resource.data.role
        && request.resource.data.uid == resource.data.uid;
    }

    // ---------- Users ----------
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.role == 'customer'
        && request.resource.data.uid == userId;
      allow update: if (isOwner(userId) && isSafeUserUpdate()) || (isAdmin() && isAdminUserUpdate());
    }

    match /users/{userId}/wishlist/{itemId} {
      allow read, create, update, delete: if isOwner(userId);
    }

    // ---------- Agent applications ----------
    match /agentApplications/{applicationId} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == currentUserId();
      allow update, delete: if isAdmin();
    }

    // ---------- Public catalog listings ----------
    function isAgentListingOwner() {
      return resource.data.ownerId == currentUserId()
        || resource.data.agentId == currentUserId()
        || resource.data.createdBy == currentUserId();
    }

    function isAgentListingCreateSafe() {
      // Agents cannot set ownership to another user or bypass moderation flags on create
      return (request.resource.data.ownerId == currentUserId()
        || request.resource.data.agentId == currentUserId()
        || request.resource.data.createdBy == currentUserId())
        && request.resource.data.published == false
        && request.resource.data.featured == false
        && (!('status' in request.resource.data) || request.resource.data.status in ['draft', 'pending_review'])
        && (!('approvalStatus' in request.resource.data) || request.resource.data.approvalStatus in ['draft', 'pending_review']);
    }

    function isAgentListingUpdateSafe() {
      // Agents cannot change ownership, published, featured, or status to approved/rejected/suspended
      let incomingKeys = request.resource.data.diff(resource.data).affectedKeys();
      return (!incomingKeys.hasAny(['ownerId', 'agentId', 'createdBy']))
        && (!incomingKeys.hasAny(['published', 'featured']))
        && (!incomingKeys.hasAny(['status'])
            || !(request.resource.data.status in ['approved', 'rejected', 'suspended']))
        && (!incomingKeys.hasAny(['approvalStatus'])
            || !(request.resource.data.approvalStatus in ['approved', 'rejected', 'suspended']));
    }

    match /tours/{itemId} {
      allow read: if resource.data.published == true || isApprovedAgent() || isAdmin();
      allow create: if isApprovedAgent() && isAgentListingCreateSafe();
      allow update: if isAdmin() || (isApprovedAgent() && isAgentListingOwner() && isAgentListingUpdateSafe());
      allow delete: if isAdmin() || (isApprovedAgent() && isAgentListingOwner());
    }

    match /hotels/{itemId} {
      allow read: if resource.data.published == true || isApprovedAgent() || isAdmin();
      allow create: if isApprovedAgent() && isAgentListingCreateSafe();
      allow update: if isAdmin() || (isApprovedAgent() && isAgentListingOwner() && isAgentListingUpdateSafe());
      allow delete: if isAdmin() || (isApprovedAgent() && isAgentListingOwner());
    }

    match /cars/{itemId} {
      allow read: if resource.data.published == true
        || isAdmin()
        || (isApprovedAgent() && isAgentListingOwner());
      allow create: if isApprovedAgent() && isAgentListingCreateSafe();
      allow update: if isAdmin() || (isApprovedAgent() && isAgentListingOwner() && isAgentListingUpdateSafe());
      allow delete: if isAdmin() || (isApprovedAgent() && isAgentListingOwner());
    }

    match /flights/{itemId} {
      allow read: if resource.data.published == true
        || isAdmin()
        || (isApprovedAgent() && isAgentListingOwner());
      allow create: if isApprovedAgent() && isAgentListingCreateSafe();
      allow update: if isAdmin() || (isApprovedAgent() && isAgentListingOwner() && isAgentListingUpdateSafe());
      allow delete: if isAdmin() || (isApprovedAgent() && isAgentListingOwner());
    }

    match /activities/{itemId} {
      allow read: if resource.data.published == true
        || isAdmin()
        || (isApprovedAgent() && isAgentListingOwner());
      allow create: if isApprovedAgent() && isAgentListingCreateSafe();
      allow update: if isAdmin() || (isApprovedAgent() && isAgentListingOwner() && isAgentListingUpdateSafe());
      allow delete: if isAdmin() || (isApprovedAgent() && isAgentListingOwner());
    }

    match /resorts/{itemId} {
      allow read: if resource.data.published == true
        || isAdmin()
        || (isApprovedAgent() && isAgentListingOwner());
      allow create: if isApprovedAgent() && isAgentListingCreateSafe();
      allow update: if isAdmin() || (isApprovedAgent() && isAgentListingOwner() && isAgentListingUpdateSafe());
      allow delete: if isAdmin() || (isApprovedAgent() && isAgentListingOwner());
    }

    match /chalets/{itemId} {
      allow read: if resource.data.published == true
        || isAdmin()
        || (isApprovedAgent() && isAgentListingOwner());
      allow create: if isApprovedAgent() && isAgentListingCreateSafe();
      allow update: if isAdmin() || (isApprovedAgent() && isAgentListingOwner() && isAgentListingUpdateSafe());
      allow delete: if isAdmin() || (isApprovedAgent() && isAgentListingOwner());
    }

    // ---------- Bookings ----------
    function isBookingAgent() {
      return resource.data.agentId == currentUserId();
    }

    function isProtectedBookingField(field) {
      return field in ['userId', 'agentId', 'customerId', 'itemId', 'itemType', 'price', 'totalAmount', 'paymentStatus', 'transactionId', 'transactionIds', 'paymentMethod', 'createdAt'];
    }

    function isAgentBookingUpdateSafe() {
      let incomingKeys = request.resource.data.diff(resource.data).affectedKeys();
      return !incomingKeys.hasAny(['userId', 'agentId', 'customerId', 'itemId', 'itemType', 'price', 'totalAmount', 'paymentStatus', 'transactionId', 'transactionIds', 'paymentMethod', 'createdAt'])
        && request.resource.data.status in ['pending', 'confirmed', 'completed', 'cancelled', 'rejected'];
    }

    match /bookings/{bookingId} {
      allow read: if isOwner(resource.data.userId)
        || ((isApprovedAgent() || isAgent()) && isBookingAgent())
        || isAdmin();
      allow create: if isCustomer()
        && request.resource.data.userId == currentUserId()
        && request.resource.data.status == 'pending';
      allow update: if isAdmin()
        || ((isApprovedAgent() || isAgent()) && isBookingAgent() && isAgentBookingUpdateSafe())
        || (isOwner(resource.data.userId) && request.resource.data.status == 'cancelled');
    }

    // ---------- Favorites (customer-owned) ----------
    match /favorites/{favoriteId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isCustomer() && request.resource.data.userId == currentUserId();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ---------- Reviews ----------
    match /reviews/{reviewId} {
      allow read: if resource.data.published == true
        || isAdmin()
        || ((isApprovedAgent() || isAgent()) && (resource.data.agentId == currentUserId() || get(/databases/$(database)/documents/$(resource.data.itemCollection)/$(resource.data.itemId)).data.ownerId == currentUserId()));
      allow create: if isCustomer() && request.resource.data.userId == currentUserId();
      allow update: if isAdmin()
        || (isOwner(resource.data.userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['comment', 'updatedAt']))
        || ((isApprovedAgent() || isAgent()) && resource.data.agentId == currentUserId() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['agentResponse', 'agentRespondedAt', 'updatedAt']));
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ---------- Notifications ----------
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAdmin()
        || ((isApprovedAgent() || isAgent()) && request.resource.data.userId == currentUserId());
      allow update: if (isOwner(resource.data.userId) && request.resource.data.keys().hasOnly(['read', 'readAt', 'updatedAt']))
        || isAdmin();
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ---------- Enquiries ----------
    match /enquiries/{enquiryId} {
      allow read: if isAdmin() || ((isApprovedAgent() || isAgent()) && resource.data.agentId == currentUserId());
      allow create: if isCustomer() || isSignedIn();
      allow update: if isAdmin()
        || ((isApprovedAgent() || isAgent()) && resource.data.agentId == currentUserId() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'agentResponse', 'updatedAt']));
      allow delete: if isAdmin() || ((isApprovedAgent() || isAgent()) && resource.data.agentId == currentUserId());
    }

    // ---------- Coupons (admin-only) ----------
    match /coupons/{couponId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ---------- Settings (admin-only) ----------
    match /settings/{document} {
      allow read, write: if isAdmin();
    }

    // ---------- Site settings (homepage content, global config) ----------
    match /siteSettings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------- Default deny ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
